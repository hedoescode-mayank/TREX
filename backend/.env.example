# Backend Configuration
# Port and Host
API_PORT=8000
API_HOST=0.0.0.0

# CORS (Comma separated URLs)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Environment
ENVIRONMENT=development

# AI Providers (Fill these with your keys)
